{% comment %}
  LP — Offerta (B2C landing page)

  Code-only LP element. Edit this file to change product handles,
  copy, modal contents, or the trust block. Not editable through
  the Shopify theme editor by design.

  Cart flow: clicking the main CTA opens the gift t-shirt modal.
  Confirm in modal -> POST /cart/add.js with [shoe, tshirt]
  -> redirect to /discount/BUNDLETSHIRT?redirect=/checkout?discount=SPEDIZIONEGRATIS
  See assets/lp-offerta.js for the CFG block + flow.

  To change the discount codes or viewer range, edit assets/lp-offerta.js (top of file).
  To change product references, edit the two `assign` lines below.
{% endcomment %}

{%- assign product = all_products['dr-kampes-s3s'] -%}
{%- assign tshirt_product = all_products['t-shirt-dr-kampes'] -%}
{%- assign first_variant = product.selected_or_first_available_variant -%}

{{ 'lp-offerta.css' | asset_url | stylesheet_tag }}

{% if product == blank %}
  <div style="padding:2rem;text-align:center;color:#888;">Nessun prodotto configurato in lp-offerta.liquid</div>
{% else %}

<div class="hps" id="acquista" data-hps-id="lp">

  <script type="application/json" id="hps-variants-lp">
    {{ product.variants | json }}
  </script>

  <script type="application/json" id="hps-vg-lp">
    {
      {%- for variant in product.variants -%}
        {%- unless forloop.first -%},{%- endunless -%}
        "{{ variant.id }}": [
          {%- assign vg_files = variant.metafields.custom.variant_gallery.value -%}
          {%- if vg_files != blank -%}
            {%- assign first_hit = true -%}
            {%- for vg_file in vg_files -%}
              {%- for media in product.media -%}
                {%- if vg_file.image.src == media.src -%}
                  {%- unless first_hit -%},{%- endunless -%}
                  {{ media.id }}
                  {%- assign first_hit = false -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endfor -%}
          {%- endif -%}
        ]
      {%- endfor -%}
    }
  </script>

  {%- if tshirt_product != blank -%}
    <script type="application/json" id="hps-tshirt-variants-lp">
      {{ tshirt_product.variants | json }}
    </script>
  {%- endif -%}

  {%- assign hps_compare = 21900 -%}
  {%- assign hps_savings = hps_compare | minus: product.price | divided_by: 100 -%}
  {%- assign hps_pct = hps_compare | minus: product.price | times: 100 | divided_by: hps_compare -%}

  <div class="hps__head">
    <h2 class="hps__title">{{ product.title }}</h2>
    <div class="hps__social">
      <span class="hps__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
      <span class="hps__review-lbl"><strong>4,9/5</strong> da oltre 1200 camionisti soddisfatti</span>
    </div>
    <div class="hps__price-wrap">
      <div class="hps__price-row">
        <span class="hps__price-main">&euro;{{ product.price | money_without_currency }}</span>
        <span class="hps__price-compare">&euro;219,00</span>
        {%- if hps_pct > 0 -%}
          <span class="hps__discount-badge">-{{ hps_pct }}%</span>
        {%- endif -%}
      </div>
      <p class="hps__installment">Oppure <strong>3 rate da &euro;63,00</strong> con Klarna o PayPal</p>
    </div>
  </div>

  <div class="hps__gallery">
    <div class="hps__main">
      {%- for media in product.media -%}
        <div
          class="hps__slide{% if forloop.first %} hps__slide--active{% endif %}"
          data-media-id="{{ media.id }}"
        >
          {%- if forloop.first -%}
            {{ media | image_url: width: 1200 | image_tag: class: 'hps__img', loading: 'eager', widths: '600,800,1100,1400', sizes: '(max-width:749px) 100vw, 50vw' }}
          {%- else -%}
            {{ media | image_url: width: 1200 | image_tag: class: 'hps__img', loading: 'lazy', widths: '600,800,1100,1400', sizes: '(max-width:749px) 100vw, 50vw' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
      <button type="button" class="hps__nav hps__nav--prev" aria-label="Immagine precedente">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <button type="button" class="hps__nav hps__nav--next" aria-label="Immagine successiva">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>

    <div class="hps__thumbs">
      {%- for media in product.media -%}
        <button
          type="button"
          class="hps__thumb{% if forloop.first %} hps__thumb--active{% endif %}"
          data-index="{{ forloop.index0 }}"
          data-media-id="{{ media.id }}"
          aria-label="Immagine {{ forloop.index }}"
        >{{ media | image_url: width: 160 | image_tag: class: 'hps__thumb-img', loading: 'lazy' }}</button>
      {%- endfor -%}
    </div>

  </div>

  <div class="hps__details">

    {%- comment %}
      Form wrapper dropped on purpose. The CTA opens a modal and the
      cart-add happens via fetch in lp-offerta.js. We never submit a
      browser-native form. Using a plain <div> keeps Dawn's product-form
      Custom Element out of the picture.
    {%- endcomment %}
    <div class="hps__form" id="hps-form-lp">
      <input type="hidden" name="id" id="hps-vid-lp" value="{{ first_variant.id }}">

      {%- assign color_option = nil -%}
      {%- assign color_pos = 0 -%}
      {%- for option in product.options_with_values -%}
        {%- assign n = option.name | downcase -%}
        {%- if n == 'colore' or n == 'color' or n == 'colour' -%}
          {%- assign color_option = option -%}
          {%- assign color_pos = option.position | minus: 1 -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if color_option != nil -%}
        <div class="hps__opt">
          <p class="hps__opt-lbl">COLORE: <span id="hps-cval-lp">{{ color_option.selected_value | upcase }}</span></p>
          <div class="hps__swatches">
            {%- for value in color_option.values -%}
              <button
                type="button"
                class="hps__swatch{% if color_option.selected_value == value %} hps__swatch--on{% endif %}"
                data-color="{{ value }}"
                data-pos="{{ color_pos }}"
                title="{{ value }}"
                aria-label="{{ value }}"
                {%- assign sw = value.swatch -%}
                {%- assign val_h = value | handleize -%}
                style="{% if sw.color %}background:rgb({{ sw.color.rgb }});{% elsif sw.image %}background:url('{{ sw.image | image_url: width: 80 }}') center/cover no-repeat;{% elsif val_h == 'nero' %}background:#1a1a1a;{% elsif val_h == 'testa-di-moro' or val_h == 'testa-moro' %}background:#3d1a0a;{% elsif val_h == 'marrone' or val_h == 'brown' %}background:#5c3317;{% else %}background:#888;{% endif %}"
              ></button>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      {%- assign size_option = nil -%}
      {%- assign size_pos = 1 -%}
      {%- for option in product.options_with_values -%}
        {%- assign n = option.name | downcase -%}
        {%- if n == 'taglia' or n == 'size' or n == 'misura' -%}
          {%- assign size_option = option -%}
          {%- assign size_pos = option.position | minus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if size_option == nil -%}
        {%- for option in product.options_with_values -%}
          {%- if option.position != color_option.position -%}
            {%- assign size_option = option -%}
            {%- assign size_pos = option.position | minus: 1 -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      {%- if size_option != nil -%}
        <div class="hps__opt">
          <div class="hps__size-row">
            <p class="hps__opt-lbl">TAGLIA: <span id="hps-sval-lp">{{ size_option.selected_value }}</span></p>
            <div class="hps__size-row-actions">
              <button type="button" class="hps__size-guide" id="hps-size-lp">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8h18v8H3z"/><path d="M7 8v3M11 8v3M15 8v3M19 8v3"/></svg>
                <span>Guida alle taglie</span>
              </button>
              <button type="button" class="hps__size-guide" id="hps-tech-lp">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M9 13h6"/><path d="M9 17h6"/></svg>
                <span>Specifiche</span>
              </button>
            </div>
          </div>
          <div class="hps__pills hps__pills--sizes" id="hps-ssel-lp" data-pos="{{ size_pos }}" role="group" aria-label="Taglia">
            {%- for value in size_option.values -%}
              {%- assign pill_avail = false -%}
              {%- for variant in product.variants -%}
                {%- if variant.options[size_pos] == value and variant.available -%}
                  {%- assign pill_avail = true -%}
                {%- endif -%}
              {%- endfor -%}
              <button
                type="button"
                class="hps__pill{% if size_option.selected_value == value %} hps__pill--on{% endif %}{% unless pill_avail %} hps__pill--unavail{% endunless %}"
                data-value="{{ value }}"
                data-pos="{{ size_pos }}"
                {% unless pill_avail %}aria-disabled="true"{% endunless %}
              >{{ value }}</button>
            {%- endfor -%}
          </div>
          <p class="hps__stock" id="hps-stock-lp" hidden>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="13" r="8"/><path d="M12 9v4l2.5 2.5"/><path d="M9 2h6"/></svg>
            <span>MENO DI <span class="hps-stock-n">7</span> PAIA RIMASTE</span>
          </p>
        </div>
      {%- endif -%}

      <div class="hps__cta-group">
        <button type="button" class="hps__bn hps__bn--primary" id="hps-bn-lp">
          <svg class="hps__bn-lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="11" width="16" height="10" rx="1"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
          <span class="hps__bn-text">PRENOTA ORA LA TUA TAGLIA</span>
          <svg class="hps__bn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
        </button>
      </div>

    </div>

    <div class="hps__trust">
      <div class="hps__trust-item">
        <svg class="hps__trust-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        <strong>3 ANNI DI GARANZIA</strong>
        <span>Acquistale oggi e <b>indossale per anni</b>.</span>
      </div>
      <div class="hps__trust-item">
        <svg class="hps__trust-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
        <strong>CAMBIO TAGLIA GRATUITO</strong>
        <span>Se non &egrave; la taglia giusta, <b>la cambiamo noi</b>.</span>
      </div>
      <div class="hps__trust-item">
        <svg class="hps__trust-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v4h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        <strong>SPEDIZIONE GRATIS 1-2 GIORNI</strong>
        <span>Ordina prima delle <b>19:00</b>, spediamo <b>il giorno dopo</b>.</span>
      </div>
      <div class="hps__trust-item">
        <svg class="hps__trust-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="6" width="20" height="13" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/><line x1="6" y1="15" x2="9" y2="15"/></svg>
        <strong>PAGA IN 3 RATE SENZA INTERESSI</strong>
        <span>Scegli <b>Klarna</b> o <b>PayPal</b> al checkout.</span>
      </div>
    </div>

  </div>
</div>

<div class="hps__viewer-toast" id="hps-viewers-lp"><span class="hps-viewers-dot"></span><span class="hps-viewers-n">0</span> persone stanno guardando</div>

<div class="hps-pop" id="hps-pop-tshirt-lp" role="dialog" aria-modal="true" aria-labelledby="hps-tshirt-title-lp" hidden>
  <div class="hps-pop__bg" data-pop-close></div>
  <div class="hps-pop__box hps-pop__box--offer">
    <button type="button" class="hps-pop__x" data-pop-close aria-label="Chiudi">&times;</button>
    <div class="hps-pop__eyebrow">
      <span aria-hidden="true">🎁</span> T-SHIRT OMAGGIO INCLUSA
    </div>
    <h3 class="hps-pop__title" id="hps-tshirt-title-lp">Scegli la taglia della tua T-shirt</h3>
    {%- if tshirt_product != blank and tshirt_product.featured_image != blank -%}
      <div class="hps-tshirt-img-wrap">
        {{ tshirt_product.featured_image | image_url: width: 480 | image_tag: class: 'hps-tshirt-img', loading: 'lazy', alt: tshirt_product.title }}
      </div>
    {%- endif -%}
    <div class="hps-pop__body">
      {%- if tshirt_product != blank -%}
        <p class="hps-tshirt-product-name">{{ tshirt_product.title }}</p>
        {%- assign tshirt_first_avail = nil -%}
        {%- for variant in tshirt_product.variants -%}
          {%- if variant.available and tshirt_first_avail == nil -%}
            {%- assign tshirt_first_avail = variant -%}
          {%- endif -%}
        {%- endfor -%}
        <input type="hidden" id="hps-tshirt-sel-lp" value="{{ tshirt_first_avail.id | default: tshirt_product.variants.first.id }}">
        <p class="hps__opt-lbl hps-tshirt-lbl">TAGLIA: <span id="hps-tshirt-val-lp">{{ tshirt_first_avail.title | default: tshirt_product.variants.first.title }}</span></p>
        <div class="hps__pills hps-tshirt-pills" id="hps-tshirt-pills-lp" role="group" aria-label="Taglia T-shirt">
          {%- for variant in tshirt_product.variants -%}
            <button
              type="button"
              class="hps__pill{% if variant.id == tshirt_first_avail.id %} hps__pill--on{% endif %}{% unless variant.available %} hps__pill--unavail{% endunless %}"
              data-variant-id="{{ variant.id }}"
              data-title="{{ variant.title }}"
              {% unless variant.available %}aria-disabled="true"{% endunless %}
            >{{ variant.title }}</button>
          {%- endfor -%}
        </div>
      {%- else -%}
        <p style="color:#888;font-size:0.85rem;">Nessuna t-shirt configurata.</p>
      {%- endif -%}
    </div>
    <button type="button" id="hps-confirm-lp" class="hps__atc hps__atc--confirm">
      <svg class="hps__bn-lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="11" width="16" height="10" rx="1"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
      <span class="hps__bn-text">CONFERMA E VAI AL CHECKOUT</span>
      <svg class="hps__bn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
    </button>
    <p class="hps__micro hps-tshirt-disclaimer">
      Entrambi i prodotti vengono aggiunti al carrello. Il codice spedizione gratuita viene applicato automaticamente al checkout.
    </p>
  </div>
</div>

<div class="hps-pop" id="hps-pop-tech-lp" role="dialog" aria-modal="true" hidden>
  <div class="hps-pop__bg" data-pop-close></div>
  <div class="hps-pop__box">
    <button type="button" class="hps-pop__x" data-pop-close aria-label="Chiudi">&times;</button>
    <h3 class="hps-pop__title">Documentazione Tecnica</h3>
    <div class="hps-pop__body">
      <div class="hps-doc-section">
        <p class="hps-doc-section__label">Documenti comuni</p>
        <a class="hps-doc-row" href="https://cdn.shopify.com/s/files/1/0960/9527/3303/files/DPI-DRKAMPES-CERTIFICAZIONE-S3S.pdf?v=1776677825" target="_blank" rel="noopener">
          <span class="hps-doc-row__icon">&#8595;</span>
          <span class="hps-doc-row__name">Certificazione DPI S3S</span>
          <span class="hps-doc-row__type">PDF</span>
        </a>
        <a class="hps-doc-row" href="https://cdn.shopify.com/s/files/1/0960/9527/3303/files/NOTA-INFORMATIVA-DRKAMPES.pdf?v=1776677825" target="_blank" rel="noopener">
          <span class="hps-doc-row__icon">&#8595;</span>
          <span class="hps-doc-row__name">Nota informativa</span>
          <span class="hps-doc-row__type">PDF</span>
        </a>
      </div>
      <div class="hps-doc-section">
        <p class="hps-doc-section__label">Schede tecniche per modello</p>
        <a class="hps-doc-row" href="https://cdn.shopify.com/s/files/1/0960/9527/3303/files/DR_KAMPES_-_SCHEDA_TECNICA-20260420-BLACK.pdf?v=1776677825" target="_blank" rel="noopener">
          <span class="hps-doc-row__icon">&#8595;</span>
          <span class="hps-doc-row__name">Dr Kampes Nere</span>
          <span class="hps-doc-row__type">PDF</span>
        </a>
        <a class="hps-doc-row" href="https://cdn.shopify.com/s/files/1/0960/9527/3303/files/DR_KAMPES_-_SCHEDA_TECNICA-20260420-BLACK.pdf?v=1776677825" target="_blank" rel="noopener">
          <span class="hps-doc-row__icon">&#8595;</span>
          <span class="hps-doc-row__name">Dr Kampes Testa di Moro</span>
          <span class="hps-doc-row__type">PDF</span>
        </a>
      </div>
    </div>
  </div>
</div>

<div class="hps-pop" id="hps-pop-size-lp" role="dialog" aria-modal="true" hidden>
  <div class="hps-pop__bg" data-pop-close></div>
  <div class="hps-pop__box">
    <button type="button" class="hps-pop__x" data-pop-close aria-label="Chiudi">&times;</button>
    <h3 class="hps-pop__title">Guida alla Taglia</h3>
    <div class="hps-pop__body">
      <p>Misura la lunghezza interna della soletta e confronta con la tabella.</p>
      <table class="hps-stbl">
        <thead><tr><th>IT</th><th>Cm Soletta Interna</th></tr></thead>
        <tbody>
          <tr><td>37</td><td>24,5 cm</td></tr>
          <tr><td>38</td><td>25 cm</td></tr>
          <tr><td>39</td><td>25,5 cm</td></tr>
          <tr><td>40</td><td>26,5 cm</td></tr>
          <tr><td>41</td><td>27,5 cm</td></tr>
          <tr><td>42</td><td>28 cm</td></tr>
          <tr><td>43</td><td>28,5 cm</td></tr>
          <tr><td>44</td><td>29 cm</td></tr>
          <tr><td>45</td><td>30 cm</td></tr>
          <tr><td>46</td><td>30,5 cm</td></tr>
          <tr><td>47</td><td>31 cm</td></tr>
          <tr><td>48</td><td>32 cm</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="hps-cta-bar" id="hps-cta-bar-lp">
  <button type="button" class="hps-cta hps-cta--after" id="hps-cta-bn-lp">
    <span class="hps-cta-bar__label">PRENOTA ORA LA TUA TAGLIA</span>
  </button>
</div>

<script src="{{ 'lp-offerta.js' | asset_url }}" defer></script>

{% endif %}
