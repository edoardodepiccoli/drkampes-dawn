{% comment %}
  LP — Navbar (B2C + B2B landing pages)

  Code-only LP element. Edit this file to change copy, logo, or trust items.
  Not editable through the Shopify theme editor by design.

  To swap the logo:        change the filename in `<img src="...">` below.
                           File must live in Shopify admin > Settings > Files.
  To swap an icon:         change `{{ icon_<name> }}` to another captured icon.
  To add a new icon:       add a {% raw %}{%- capture icon_X -%}<svg>...</svg>{%- endcapture -%}{% endraw %} above.
  To add / remove items:   copy or delete a <li> in the .lp-navbar__track block.
{% endcomment %}

{{ 'lp-navbar.css' | asset_url | stylesheet_tag }}

{%- capture icon_truck -%}<svg viewBox="0 0 32 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 4h18v13H1z"/><path d="M19 9h6l5 4v4h-11z"/><circle cx="8" cy="20" r="2.5"/><circle cx="24" cy="20" r="2.5"/></svg>{%- endcapture -%}
{%- capture icon_swap -%}<svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a10 10 0 0 1 17-7l2 2"/><path d="M23 3v6h-6"/><path d="M24 14a10 10 0 0 1-17 7l-2-2"/><path d="M5 25v-6h6"/></svg>{%- endcapture -%}
{%- capture icon_shield -%}<svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2 4 6v8c0 6 4 10 10 12 6-2 10-6 10-12V6z"/><path d="M9.5 14l3 3 6-6"/></svg>{%- endcapture -%}
{%- capture icon_medal -%}<svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="14" cy="17" r="7"/><path d="M9 12 6 2h6l3 7"/><path d="M19 12l3-10h-6l-3 7"/></svg>{%- endcapture -%}
{%- capture icon_lock -%}<svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="12" width="16" height="12" rx="1.5"/><path d="M9 12V8a5 5 0 0 1 10 0v4"/></svg>{%- endcapture -%}
{%- capture icon_star -%}<svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="m14 3 3.5 7 7.5 1-5.5 5.3 1.3 7.7L14 20.5 7.2 24l1.3-7.7L3 11l7.5-1z"/></svg>{%- endcapture -%}
{%- capture icon_check -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>{%- endcapture -%}

<section class="lp-navbar" style="--lp-navbar-logo-h: 56px;">
  <div class="lp-navbar__inner">
    <div class="lp-navbar__logo-wrap">
      {%- comment %} Logo file lives in Shopify admin > Settings > Files. {%- endcomment %}
      <img
        src="{{ 'logo_white_transparent.png' | file_url }}"
        alt="{{ shop.name | escape }}"
        class="lp-navbar__logo"
        loading="eager"
        fetchpriority="high"
        width="600"
      >
    </div>

    <div class="lp-navbar__marquee" aria-label="Vantaggi">
      <ul class="lp-navbar__track" role="list">
        <li class="lp-navbar__item">
          <span class="lp-navbar__icon" aria-hidden="true">{{ icon_truck }}</span>
          <span class="lp-navbar__text">
            <span class="lp-navbar__line1">SPEDIZIONE</span>
            <span class="lp-navbar__line2">GRATUITA</span>
          </span>
        </li>

        <li class="lp-navbar__item lp-navbar__item--desktop-only">
          <span class="lp-navbar__icon" aria-hidden="true">{{ icon_swap }}</span>
          <span class="lp-navbar__text">
            <span class="lp-navbar__line1">CAMBIO TAGLIA</span>
            <span class="lp-navbar__line2">GRATUITO</span>
          </span>
        </li>

        <li class="lp-navbar__item">
          <span class="lp-navbar__icon" aria-hidden="true">{{ icon_shield }}</span>
          <span class="lp-navbar__text">
            <span class="lp-navbar__line1">GARANZIA</span>
            <span class="lp-navbar__line2">3 ANNI</span>
          </span>
        </li>
      </ul>
    </div>
  </div>
</section>
