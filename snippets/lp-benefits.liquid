{% comment %}
  LP — Benefits (B2C landing page)

  Code-only LP element. Edit this file to change copy or icons.
  Not editable through the Shopify theme editor by design.

  Icon and shoe images are hosted on the Shopify CDN. Update the URLs
  inline to swap an icon.
{% endcomment %}

{{ 'lp-benefits.css' | asset_url | stylesheet_tag }}

<section class="lp-benefits">
  <div class="lp-benefits__inner">

    <div class="lp-benefits__top">
      <div class="lp-benefits__head">
        <div class="lp-benefits__eyebrow">PERCHÉ DR.KAMPES</div>

        <h2 class="lp-benefits__h2">
          <span class="lp-benefits__h2-line">LE SCARPE PER CHI<br>GUIDA UN MEZZO,</span>
          <span class="lp-benefits__h2-line lp-benefits__h2-line--gold">SUL SERIO.</span>
        </h2>

        <div class="lp-benefits__sub">
          <p>L'unica antinfortunistica progettata dagli autisti, per gli autisti.</p>
          <p><strong>FASTWEAR®</strong>: 3 anni di garanzia, 100% Made in Italy.</p>
        </div>
      </div>

      <div class="lp-benefits__shoe">
        <img src="https://cdn.shopify.com/s/files/1/0960/9527/3303/files/hero_04.png?v=1777976292"
             alt="Scarpa Dr.Kampes"
             loading="lazy"
             decoding="async">
      </div>
    </div>

    <ul class="lp-benefits__list">

      <li class="lp-benefit-row">
        <span class="lp-benefit-row__icon" aria-hidden="true">
          <img src="https://cdn.shopify.com/s/files/1/0960/9527/3303/files/cronometro.png?v=1777976336" alt="" loading="lazy" decoding="async">
        </span>
        <div class="lp-benefit-row__body">
          <div class="lp-benefit-row__title-line">
            <strong class="lp-benefit-row__title">FASTWEAR®</strong>
            <span class="lp-benefit-row__sep" aria-hidden="true"> &mdash; </span>
            <span class="lp-benefit-row__suffix">indossi in 1 secondo, senza lacci</span>
          </div>
          <p class="lp-benefit-row__text">Entra e esci in un attimo. Niente lacci, niente perdite di tempo.</p>
        </div>
      </li>

      <li class="lp-benefit-row">
        <span class="lp-benefit-row__icon" aria-hidden="true">
          <img src="https://cdn.shopify.com/s/files/1/0960/9527/3303/files/scudo.png?v=1777976336" alt="" loading="lazy" decoding="async">
        </span>
        <div class="lp-benefit-row__body">
          <div class="lp-benefit-row__title-line">
            <strong class="lp-benefit-row__title">3 anni di garanzia reale</strong>
            <span class="lp-benefit-row__sep" aria-hidden="true"> &mdash; </span>
            <span class="lp-benefit-row__suffix">1095 giorni coperti</span>
          </div>
          <p class="lp-benefit-row__text">Qualità che dura nel tempo. Se c'è un problema, lo risolviamo noi.</p>
        </div>
      </li>

      <li class="lp-benefit-row">
        <span class="lp-benefit-row__icon" aria-hidden="true">
          <img src="https://cdn.shopify.com/s/files/1/0960/9527/3303/files/italia.png?v=1777976336" alt="" loading="lazy" decoding="async">
        </span>
        <div class="lp-benefit-row__body">
          <div class="lp-benefit-row__title-line">
            <strong class="lp-benefit-row__title">100% Made in Italy</strong>
            <span class="lp-benefit-row__sep" aria-hidden="true"> &mdash; </span>
            <span class="lp-benefit-row__suffix">Montebelluna, Treviso</span>
          </div>
          <p class="lp-benefit-row__text">Produzione italiana, materiali selezionati, controllo totale.</p>
        </div>
      </li>

      <li class="lp-benefit-row">
        <span class="lp-benefit-row__icon" aria-hidden="true">
          <img src="https://cdn.shopify.com/s/files/1/0960/9527/3303/files/antiperforazione.png?v=1777976336" alt="" loading="lazy" decoding="async">
        </span>
        <div class="lp-benefit-row__body">
          <div class="lp-benefit-row__title-line">
            <strong class="lp-benefit-row__title">Intersuola antiforatura</strong>
            <span class="lp-benefit-row__sep" aria-hidden="true"> &mdash; </span>
            <span class="lp-benefit-row__suffix">sicurezza ogni giorno</span>
          </div>
          <p class="lp-benefit-row__text">Protezione certificata contro le perforazioni. Lavori in tranquillità.</p>
        </div>
      </li>

      <li class="lp-benefit-row">
        <span class="lp-benefit-row__icon" aria-hidden="true">
          <img src="https://cdn.shopify.com/s/files/1/0960/9527/3303/files/antivibrazione.png?v=1777976336" alt="" loading="lazy" decoding="async">
        </span>
        <div class="lp-benefit-row__body">
          <div class="lp-benefit-row__title-line">
            <strong class="lp-benefit-row__title">Plantare anti-vibrazione</strong>
            <span class="lp-benefit-row__sep" aria-hidden="true"> &mdash; </span>
            <span class="lp-benefit-row__suffix">11h di guida senza dolore</span>
          </div>
          <p class="lp-benefit-row__text">Assorbe gli urti e riduce l'affaticamento. Piedi e schiena ringraziano.</p>
        </div>
      </li>

      <li class="lp-benefit-row">
        <span class="lp-benefit-row__icon" aria-hidden="true">
          <img src="https://cdn.shopify.com/s/files/1/0960/9527/3303/files/S3S_protezione.png?v=1777976336" alt="" loading="lazy" decoding="async">
        </span>
        <div class="lp-benefit-row__body">
          <div class="lp-benefit-row__title-line">
            <strong class="lp-benefit-row__title">S3S grado massimo UE</strong>
            <span class="lp-benefit-row__sep" aria-hidden="true"> &mdash; </span>
            <span class="lp-benefit-row__suffix">antiscivolo, gasolio, lamiere, ghiaccio</span>
          </div>
          <p class="lp-benefit-row__text">Massima protezione certificata in ogni condizione di lavoro.</p>
        </div>
      </li>

    </ul>

    <div class="lp-benefits__cabin">
      <h3 class="lp-benefits__cabin-heading">PENSATE PER CHI VIVE IN CABINA</h3>

      <div class="lp-benefits__cabin-grid">

        <div class="lp-cabin-card">
          <div class="lp-cabin-card__icon">
            <img src="https://cdn.shopify.com/s/files/1/0960/9527/3303/files/piede.png?v=1777976336" alt="" loading="lazy" decoding="async">
          </div>
          <h4 class="lp-cabin-card__title">COMODE<br>TUTTO IL GIORNO</h4>
          <p class="lp-cabin-card__text">Niente più piedi stanchi dopo tante ore di guida.</p>
        </div>

        <div class="lp-cabin-card">
          <div class="lp-cabin-card__icon">
            <img src="https://cdn.shopify.com/s/files/1/0960/9527/3303/files/piede_02.png?v=1777976337" alt="" loading="lazy" decoding="async">
          </div>
          <h4 class="lp-cabin-card__title">VELOCI DA<br>INDOSSARE</h4>
          <p class="lp-cabin-card__text">Le infili e sei subito pronto a scendere e ripartire.</p>
        </div>

        <div class="lp-cabin-card">
          <div class="lp-cabin-card__icon">
            <img src="https://cdn.shopify.com/s/files/1/0960/9527/3303/files/goccia.png?v=1777976337" alt="" loading="lazy" decoding="async">
          </div>
          <h4 class="lp-cabin-card__title">ASCIUTTE E<br>SICURE</h4>
          <p class="lp-cabin-card__text">Materiali resistenti all'acqua e al freddo, sempre protetto.</p>
        </div>

        <div class="lp-cabin-card">
          <div class="lp-cabin-card__icon">
            <img src="https://cdn.shopify.com/s/files/1/0960/9527/3303/files/scudo_bianco.png?v=1777976337" alt="" loading="lazy" decoding="async">
          </div>
          <h4 class="lp-cabin-card__title">SICURE IN OGNI<br>CONDIZIONE</h4>
          <p class="lp-cabin-card__text">Aderenza e protezione massima su ogni superficie.</p>
        </div>

      </div>
    </div>

  </div>
</section>
