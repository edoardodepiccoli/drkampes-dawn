{% comment %}
  LP B2B — System (B2B landing page)

  Code-only LP element. Heading + subheading + horizontal scroll-snap carousel
  of 6 feature cards (palette / bolt / ruler / recycle / user-card / headset).
  Dot pagination wired via assets/lp-b2b-system.js.
{% endcomment %}

{{ 'lp-b2b-system.css' | asset_url | stylesheet_tag }}

<section class="lp-b2b-system" data-lp-b2b-system>

  <div class="lp-b2b-system__inner">

    <header class="lp-b2b-system__head">
      <h2 class="lp-b2b-system__heading">Non una semplice scarpa.</h2>
      <p class="lp-b2b-system__sub">Un segno distintivo per la tua flotta.</p>
    </header>

    <div class="lp-b2b-system__carousel">
      <ul class="lp-b2b-system__track">

        <li class="lp-b2b-system__card">
          <span class="lp-b2b-system__card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a9 9 0 0 0 0 18c1 0 2-1 2-2 0-1-1-2-1-3s1-2 2-2h3a4 4 0 0 0 4-4 9 9 0 0 0-10-7z"/><circle cx="7.5" cy="11" r="1.2"/><circle cx="11" cy="7" r="1.2"/><circle cx="16" cy="8.5" r="1.2"/></svg>
          </span>
          <div class="lp-b2b-system__card-body">
            <h3 class="lp-b2b-system__card-title">Personalizzazione aziendale</h3>
            <p class="lp-b2b-system__card-text">Colori e logo per rendere riconoscibili i tuoi autisti.</p>
          </div>
        </li>

        <li class="lp-b2b-system__card">
          <span class="lp-b2b-system__card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 4 14h7l-1 8 9-12h-7z"/></svg>
          </span>
          <div class="lp-b2b-system__card-body">
            <h3 class="lp-b2b-system__card-title">Fast Wear System</h3>
            <p class="lp-b2b-system__card-text">Più praticità quando l'autista scende dal camion.</p>
          </div>
        </li>

        <li class="lp-b2b-system__card">
          <span class="lp-b2b-system__card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="9" width="20" height="6"/><line x1="6" y1="9" x2="6" y2="12"/><line x1="10" y1="9" x2="10" y2="13"/><line x1="14" y1="9" x2="14" y2="12"/><line x1="18" y1="9" x2="18" y2="13"/></svg>
          </span>
          <div class="lp-b2b-system__card-body">
            <h3 class="lp-b2b-system__card-title">Gestione taglie</h3>
            <p class="lp-b2b-system__card-text">Sviluppiamo la base taglie aziendale, gestiamo lo storico ordini e il cambio taglia rapido.</p>
          </div>
        </li>

        <li class="lp-b2b-system__card">
          <span class="lp-b2b-system__card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7 4 10l3 3"/><path d="M4 10h11a4 4 0 0 1 4 4"/><path d="M17 17l3-3-3-3"/><path d="M20 14H9a4 4 0 0 1-4-4"/></svg>
          </span>
          <div class="lp-b2b-system__card-body">
            <h3 class="lp-b2b-system__card-title">Cambio gomme gratuito</h3>
            <p class="lp-b2b-system__card-text">Sostituzione suole consumate gratuita previa verifica dell'integrità della tomaia.</p>
          </div>
        </li>

        <li class="lp-b2b-system__card">
          <span class="lp-b2b-system__card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="0"/><circle cx="9" cy="11" r="2.5"/><path d="M5 18a4 4 0 0 1 8 0"/><line x1="14" y1="9" x2="19" y2="9"/><line x1="14" y1="12" x2="19" y2="12"/><line x1="14" y1="15" x2="17" y2="15"/></svg>
          </span>
          <div class="lp-b2b-system__card-body">
            <h3 class="lp-b2b-system__card-title">Scheda autista</h3>
            <p class="lp-b2b-system__card-text">Taglie, cambi, sostituzioni, riparazioni e perdite tracciate per ogni autista.</p>
          </div>
        </li>

        <li class="lp-b2b-system__card">
          <span class="lp-b2b-system__card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 13a8 8 0 0 1 16 0"/><rect x="3" y="13" width="4" height="7" rx="1"/><rect x="17" y="13" width="4" height="7" rx="1"/><path d="M19 20a3 3 0 0 1-3 3h-2"/></svg>
          </span>
          <div class="lp-b2b-system__card-body">
            <h3 class="lp-b2b-system__card-title">Supporto diretto</h3>
            <p class="lp-b2b-system__card-text">Un referente chiaro per ordini, riordini e assistenza.</p>
          </div>
        </li>

      </ul>

      <ul class="lp-b2b-system__dots" role="tablist" aria-label="Naviga le feature">
        <li><button type="button" class="lp-b2b-system__dot is-active" data-index="0" aria-label="Vai alla feature 1"></button></li>
        <li><button type="button" class="lp-b2b-system__dot" data-index="1" aria-label="Vai alla feature 2"></button></li>
        <li><button type="button" class="lp-b2b-system__dot" data-index="2" aria-label="Vai alla feature 3"></button></li>
        <li><button type="button" class="lp-b2b-system__dot" data-index="3" aria-label="Vai alla feature 4"></button></li>
        <li><button type="button" class="lp-b2b-system__dot" data-index="4" aria-label="Vai alla feature 5"></button></li>
        <li><button type="button" class="lp-b2b-system__dot" data-index="5" aria-label="Vai alla feature 6"></button></li>
      </ul>
    </div>

  </div>
</section>

<script src="{{ 'lp-b2b-system.js' | asset_url }}" defer></script>
