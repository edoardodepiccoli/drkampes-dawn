  # `assign` non accetta comparazioni a destra: boolean via if/endif (rules.md).
  assign is_en = false
  if request.locale.iso_code == 'en'
    assign is_en = true
  endif
  assign avatar_colors = '#f4511e,#6a1b9a,#1e88e5,#00897b,#e53935,#5e35b1,#039be5,#43a047,#8e24aa,#d81b60' | split: ','
-%}

