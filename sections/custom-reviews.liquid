{%- assign reviews = reviews_raw | split: '§' -%}

<div class="custom-reviews">
  <div class="custom-reviews__inner">

    <header class="custom-reviews__header">
      <p class="custom-reviews__eyebrow">{% if is_en %}Google reviews{% else %}Recensioni Google{% endif %}</p>
      <h2 class="custom-reviews__heading">
        {%- if is_en -%}If they say so, you can trust it.{%- else -%}Se lo dicono loro, puoi fidarti.{%- endif -%}
      </h2>
      <p class="custom-reviews__rating">
        <span class="custom-reviews__rating-num">4.9</span>
        <span class="custom-reviews__rating-stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <span class="custom-reviews__rating-label">{% if is_en %}on Google{% else %}su Google{% endif %}</span>
      </p>
    </header>

    <ul class="custom-reviews__grid">
      {%- for review in reviews -%}
        {%- liquid
          assign parts = review | split: '|'
          assign r_name = parts[0] | strip
          assign r_text = parts[1] | strip
          assign color_idx = forloop.index0 | modulo: 10
          assign r_initial = r_name | slice: 0, 1 | upcase
        -%}
        <li class="custom-reviews__card">
          <header class="custom-reviews__card-head">
            <span class="custom-reviews__avatar" style="background: {{ avatar_colors[color_idx] }};" aria-hidden="true">{{ r_initial }}</span>
            <div class="custom-reviews__card-id">
              <p class="custom-reviews__name">{{ r_name | escape }}</p>
              <p class="custom-reviews__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
            </div>
            {%- comment -%} Badge "verificata Google": stessa funzione del check di lp-reviews. {%- endcomment -%}
            <span class="custom-reviews__verified" title="{% if is_en %}Verified Google review{% else %}Recensione verificata da Google{% endif %}">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M20 6 9 17l-5-5"/></svg>
              Google
            </span>
          </header>
          <p class="custom-reviews__text">{{ r_text }}</p>
        </li>
      {%- endfor -%}
    </ul>

    {%- comment -%}
      CTA verso il profilo Google: stessa URL di ricerca usata da lp-reviews
      (non esiste una URL corta g.page nel progetto). Chevron in giu' come
      richiesto dal cliente. Verificabilita' = il punto della sezione.
    {%- endcomment -%}
    <a
      class="custom-reviews__google-link"
      href="https://www.google.com/search?q=Dr+Kampes+Italian+Trucker+Shoes+Recensioni"
      target="_blank"
      rel="noopener"
    >
      {% if is_en %}See all reviews on Google{% else %}Vedi tutte le recensioni su Google{% endif %}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polyline points="6 9 12 15 18 9"/></svg>
    </a>

  </div>
</div>

