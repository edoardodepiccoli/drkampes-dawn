{% comment %}
  CUSTOM · Video + testo — 3 righe video + testo, alternate.

  Ogni riga (block): video + titolo + descrizione + CTA. Desktop: video
  sinistra/destra/sinistra (alternato). Mobile: video sempre sopra il testo.
  Video caricati su Shopify, riproduzione click-to-play via <deferred-media>
  (componente Dawn in global.js — niente JS proprio). Vedi decision 010.
{% endcomment %}

{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
{{ 'custom-video-rows.css' | asset_url | stylesheet_tag }}

<div class="custom-video-rows color-{{ section.settings.color_scheme }}">
  <div class="custom-video-rows__inner">
    {%- for block in section.blocks -%}
      {%- liquid
        assign video = block.settings.video
        assign poster = block.settings.poster | default: video.preview_image
        # forloop.index 1,2,3 -> modulo 2 = 1,0,1: le righe pari vanno in reverse.
        assign reverse = forloop.index | modulo: 2
      -%}
      <div
        class="custom-video-rows__row{% if reverse == 0 %} custom-video-rows__row--reverse{% endif %}"
        {{ block.shopify_attributes }}
      >
        {%- comment -%} Media prima del content: su mobile (flex column) il video sta sopra. {%- endcomment -%}
        <div class="custom-video-rows__media">
          {%- if video != blank -%}
            <deferred-media class="custom-video-rows__deferred deferred-media" data-media-id="{{ video.id }}">
              <button
                class="custom-video-rows__poster deferred-media__poster"
                type="button"
                aria-label="Riproduci video"
              >
                {%- if poster != blank -%}
                  <img
                    class="custom-video-rows__poster-img"
                    src="{{ poster | image_url: width: 1600 }}"
                    srcset="
                      {{ poster | image_url: width: 750 }} 750w,
                      {{ poster | image_url: width: 1100 }} 1100w,
                      {{ poster | image_url: width: 1600 }} 1600w
                    "
                    sizes="(min-width: 750px) 50vw, 100vw"
                    alt="{{ poster.alt | escape }}"
                    width="{{ poster.width }}"
                    height="{{ poster.height }}"
                    loading="lazy"
                  >
                {%- endif -%}
                <span class="deferred-media__poster-button motion-reduce">
                  <span class="svg-wrapper">{{- 'icon-play.svg' | inline_asset_content -}}</span>
                </span>
              </button>
              <template>
                {{
                  video
                  | video_tag:
                    image_size: '1100x',
                    autoplay: true,
                    loop: false,
                    controls: true,
                    muted: false
                }}
              </template>
            </deferred-media>
          {%- endif -%}
        </div>

        <div class="custom-video-rows__content">
          {%- if block.settings.heading != blank -%}
            <h3 class="custom-video-rows__heading">{{ block.settings.heading }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <div class="custom-video-rows__text rte">{{ block.settings.text }}</div>
          {%- endif -%}
          {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
            <a
              href="{{ block.settings.button_link }}"
              class="custom-video-rows__cta button button--primary"
            >
              {{ block.settings.button_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "CUSTOM · Video + testo",
  "tag": "section",
  "class": "custom-video-rows-section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Schema colore",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Riga",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "image_picker",
          "id": "poster",
          "label": "Poster (opzionale)",
          "info": "Se vuoto usa l'anteprima del video."
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Titolo",
          "default": "Titolo della riga"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Descrizione",
          "default": "<p>Descrizione della riga.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Testo bottone"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Link bottone"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CUSTOM · Video + testo",
      "blocks": [
        { "type": "row" },
        { "type": "row" },
        { "type": "row" }
      ]
    }
  ]
}
{% endschema %}
