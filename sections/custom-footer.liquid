{% schema %}
{
  "name": "CUSTOM · Footer",
  "tag": "footer",
  "class": "custom-footer-section",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    }
  ],
  "presets": [
    {
      "name": "CUSTOM · Footer"
    }
  ]
}
{% endschema %}
