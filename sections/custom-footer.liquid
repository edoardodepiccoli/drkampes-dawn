  <div class="custom-footer__copyright">
    {%- comment -%}
      shop.name and powered_by_link are stock Shopify globals — kept faithful
      to Dawn's footer copyright line. routes.root_url links the name home.
    {%- endcomment -%}
    <small class="custom-footer__copyright-line">
      &copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url }}
