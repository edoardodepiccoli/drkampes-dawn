{% comment %}
  CUSTOM · Gallery — gallery editoriale.

  Fino a 6 foto (editabili da editor: image_picker + didascalia per block),
  layout a 3 colonne sfalsate con parallax (le colonne scorrono a velocita'
  diverse) e reveal animato all'ingresso in viewport.
  Interattivita' in assets/custom-gallery.js. Vedi decision 009.
{% endcomment %}

{{ 'custom-gallery.css' | asset_url | stylesheet_tag }}

<custom-gallery class="custom-gallery color-{{ section.settings.color_scheme }}">
  <div class="custom-gallery__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="custom-gallery__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      {%- comment -%}
        3 colonne. I block vanno in coppie sequenziali (forloop.index0 / 2):
        col0 = block 1-2, col1 = 3-4, col2 = 5-6. Cosi' su mobile (colonne
        impilate) l'ordine resta naturale.
        data-speed: moltiplicatore parallax per colonna (lo legge custom-gallery.js).
      {%- endcomment -%}
      {%- comment -%} col0 e col2 driftano in un verso, col1 in quello opposto. {%- endcomment -%}
      {%- assign col_speeds = '0.6,-0.5,0.35' | split: ',' -%}
      <div class="custom-gallery__cols">
        {%- for col in (0..2) -%}
          <div class="custom-gallery__col" data-gallery-col data-speed="{{ col_speeds[col] }}">
            {%- for block in section.blocks -%}
              {%- assign col_of_block = forloop.index0 | divided_by: 2 -%}
              {%- if col_of_block == col -%}
                {%- assign image = block.settings.image -%}
                <figure class="custom-gallery__item" data-gallery-item {{ block.shopify_attributes }}>
                  {%- if image != blank -%}
                    <img
                      class="custom-gallery__img"
                      src="{{ image | image_url: width: 1200 }}"
                      srcset="
                        {{ image | image_url: width: 600 }} 600w,
                        {{ image | image_url: width: 900 }} 900w,
                        {{ image | image_url: width: 1200 }} 1200w,
                        {{ image | image_url: width: 1600 }} 1600w
                      "
                      sizes="(min-width: 750px) 33vw, 100vw"
                      alt="{{ image.alt | escape }}"
                      width="{{ image.width }}"
                      height="{{ image.height }}"
                      loading="lazy"
                    >
                  {%- else -%}
                    {%- comment -%} Editor: placeholder se nessuna immagine scelta. {%- endcomment -%}
                    <div class="custom-gallery__img custom-gallery__img--placeholder">
                      {{ 'image' | placeholder_svg_tag: 'custom-gallery__placeholder-svg' }}
                    </div>
                  {%- endif -%}

                  {%- if block.settings.caption != blank -%}
                    <figcaption class="custom-gallery__caption">{{ block.settings.caption | escape }}</figcaption>
                  {%- endif -%}
                </figure>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</custom-gallery>

<script src="{{ 'custom-gallery.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "CUSTOM · Gallery",
  "tag": "section",
  "class": "custom-gallery-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Schema colore",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Foto",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Foto"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Didascalia"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CUSTOM · Gallery",
      "blocks": [
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" }
      ]
    }
  ]
}
{% endschema %}
