      "settings": {
        "custom_liquid": "{% comment %}\n  Sezione Ambassador — Custom Liquid per Shopify.\n  Immagini servite dalla CDN Shopify.\n{% endcomment %}\n\n<section class=\"amb-section\" id=\"ambassadors\">\n  <div class=\"amb-inner\">\n\n    <div class=\"amb-header\">\n      <h2 class=\"amb-heading\">I Nostri Ambassador</h2>\n      <p class=\"amb-subheading\">\n        <span class=\"amb-highlight\">Più di 1.200 clienti soddisfatti</span>,\n        <span class=\"amb-highlight\">una community da 350.000 follower</span> —\n        la scarpa antinfortunistica che sta cambiando la vita dei camionisti in Italia e in Europa.\n      </p>\n    </div>\n\n    <div class=\"amb-grid\">\n\n      <!-- 01 SUPER SIMONE -->\n      <a class=\"amb-card\" href=\"https://www.instagram.com/simonesimone76/\" target=\"_blank\" rel=\"noopener\" aria-label=\"Instagram di Super Simone\">\n        <img class=\"amb-photo\" src=\"https://cdn.shopify.com/s/files/1/0960/9527/3303/files/01_SIMONE.png?v=1776167410\" alt=\"Super Simone\" loading=\"lazy\">\n        <div class=\"amb-overlay\">\n          <p class=\"amb-name\">Super Simone</p>\n          <span class=\"amb-badge\">35K+</span>\n        </div>\n      </a>\n\n      <!-- 02 PIERTUTOR -->\n      <a class=\"amb-card\" href=\"https://www.instagram.com/piertutor/\" target=\"_blank\" rel=\"noopener\" aria-label=\"Instagram di Piertutor\">\n        <img class=\"amb-photo\" src=\"https://cdn.shopify.com/s/files/1/0960/9527/3303/files/02_PIERTUTOR.png?v=1776167409\" alt=\"Piertutor\" loading=\"lazy\">\n        <div class=\"amb-overlay\">\n          <p class=\"amb-name\">Piertutor</p>\n          <span class=\"amb-badge\">80K+</span>\n        </div>\n      </a>\n\n      <!-- 03 PATRYK -->\n      <a class=\"amb-card\" href=\"https://www.instagram.com/patrykilcamionistaveneto/\" target=\"_blank\" rel=\"noopener\" aria-label=\"Instagram di Patryk il Camionista Veneto\">\n        <img class=\"amb-photo\" src=\"https://cdn.shopify.com/s/files/1/0960/9527/3303/files/03_PATRYK.png?v=1776167409\" alt=\"Patryk il Camionista Veneto\" loading=\"lazy\">\n        <div class=\"amb-overlay\">\n          <p class=\"amb-name\">Patryk il Camionista Veneto</p>\n          <span class=\"amb-badge\">60K+</span>\n        </div>\n      </a>\n\n      <!-- 04 EMANUELE EL VENETO -->\n      <a class=\"amb-card\" href=\"https://www.instagram.com/emanueleciviero/\" target=\"_blank\" rel=\"noopener\" aria-label=\"Instagram di Emanuele El Veneto\">\n        <img class=\"amb-photo\" src=\"https://cdn.shopify.com/s/files/1/0960/9527/3303/files/04_EMANUELE_EL_VENETO.png?v=1776167409\" alt=\"Emanuele El Veneto\" loading=\"lazy\">\n        <div class=\"amb-overlay\">\n          <p class=\"amb-name\">Emanuele El Veneto</p>\n          <span class=\"amb-badge\">30K+</span>\n        </div>\n      </a>\n\n      <!-- 05 JANCO -->\n      <a class=\"amb-card\" href=\"https://www.instagram.com/janco_il_camionistagram/\" target=\"_blank\" rel=\"noopener\" aria-label=\"Instagram di Janco il Camionistagram\">\n        <img class=\"amb-photo\" src=\"https://cdn.shopify.com/s/files/1/0960/9527/3303/files/05_JANCO.png?v=1776167410\" alt=\"Janco il Camionistagram\" loading=\"lazy\">\n        <div class=\"amb-overlay\">\n          <p class=\"amb-name\">Janco il Camionistagram</p>\n          <span class=\"amb-badge\">20K+</span>\n        </div>\n      </a>\n\n      <!-- 06 FEDERICO BAFFO -->\n      <a class=\"amb-card\" href=\"https://www.instagram.com/federico.baffo/\" target=\"_blank\" rel=\"noopener\" aria-label=\"Instagram di Federico Baffo\">\n        <img class=\"amb-photo\" src=\"https://cdn.shopify.com/s/files/1/0960/9527/3303/files/06_BAFFO.png?v=1776167410\" alt=\"Federico Baffo\" loading=\"lazy\">\n        <div class=\"amb-overlay\">\n          <p class=\"amb-name\">Federico Baffo</p>\n          <span class=\"amb-badge\">50K+</span>\n        </div>\n      </a>\n\n      <!-- 07 VINCENZO SCOSTUMATO -->\n      <a class=\"amb-card\" href=\"https://www.instagram.com/vincenzo_scostumato/\" target=\"_blank\" rel=\"noopener\" aria-label=\"Instagram di Vincenzo Scostumato\">\n        <img class=\"amb-photo\" src=\"https://cdn.shopify.com/s/files/1/0960/9527/3303/files/07_SCOSTUMATO.png?v=1776167410\" alt=\"Vincenzo Scostumato\" loading=\"lazy\">\n        <div class=\"amb-overlay\">\n          <p class=\"amb-name\">Vincenzo Scostumato</p>\n          <span class=\"amb-badge\">40K+</span>\n        </div>\n      </a>\n\n      <!-- 08 IL PRESIDENTE -->\n      <a class=\"amb-card\" href=\"https://www.instagram.com/rubber_duck_84__president/\" target=\"_blank\" rel=\"noopener\" aria-label=\"Instagram di Il Presidente\">\n        <img class=\"amb-photo\" src=\"https://cdn.shopify.com/s/files/1/0960/9527/3303/files/08_PRESIDENTE.png?v=1776167409\" alt=\"Il Presidente\" loading=\"lazy\">\n        <div class=\"amb-overlay\">\n          <p class=\"amb-name\">Il Presidente</p>\n          <span class=\"amb-badge\">10K+</span>\n        </div>\n      </a>\n\n      <!-- 09 MARCO VABIS -->\n      <a class=\"amb-card\" href=\"https://www.instagram.com/marco_vabis/\" target=\"_blank\" rel=\"noopener\" aria-label=\"Instagram di Marco Vabis\">\n        <img class=\"amb-photo\" src=\"https://cdn.shopify.com/s/files/1/0960/9527/3303/files/09_MARCO_VERNIA.png?v=1776167409\" alt=\"Marco Vabis\" loading=\"lazy\">\n        <div class=\"amb-overlay\">\n          <p class=\"amb-name\">Marco Vabis</p>\n          <span class=\"amb-badge\">15K+</span>\n        </div>\n      </a>\n\n      <!-- 10 IL VIKINGO -->\n      <a class=\"amb-card\" href=\"https://www.instagram.com/francescobriccarello/\" target=\"_blank\" rel=\"noopener\" aria-label=\"Instagram di Il Vikingo\">\n        <img class=\"amb-photo\" src=\"https://cdn.shopify.com/s/files/1/0960/9527/3303/files/10_IL_VIKINGO.png?v=1776167410\" alt=\"Il Vikingo\" loading=\"lazy\">\n        <div class=\"amb-overlay\">\n          <p class=\"amb-name\">Il Vikingo</p>\n          <span class=\"amb-badge\">10K+</span>\n        </div>\n      </a>\n\n      <!-- 11 CORRA GIRA MANUBRI -->\n      <a class=\"amb-card\" href=\"https://www.instagram.com/corra_gira_manubri/\" target=\"_blank\" rel=\"noopener\" aria-label=\"Instagram di Corra Gira Manubri\">\n        <img class=\"amb-photo\" src=\"https://cdn.shopify.com/s/files/1/0960/9527/3303/files/11_CORRA.png?v=1776167409\" alt=\"Corra Gira Manubri\" loading=\"lazy\">\n        <div class=\"amb-overlay\">\n          <p class=\"amb-name\">Corra Gira Manubri</p>\n          <span class=\"amb-badge\">5K+</span>\n        </div>\n      </a>\n\n    </div>\n  </div>\n</section>\n\n<style>\n  /* ===================== SECTION ===================== */\n  .amb-section {\n    background-color: #0a0a0a;\n    color: #ffffff;\n    padding: 56px 0 64px;\n    font-family: var(--font-body-family);\n    font-style: var(--font-body-style);\n    font-weight: var(--font-body-weight);\n  }\n\n  .amb-inner {\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 0 40px;\n  }\n\n  /* ===================== HEADER ===================== */\n  .amb-header {\n    text-align: center;\n    margin-bottom: 56px;\n  }\n\n  .amb-heading {\n    font-size: clamp(32px, 4vw, 48px);\n    font-family: var(--font-heading-family);\n    font-style: var(--font-heading-style);\n    font-weight: var(--font-heading-weight);\n    text-transform: uppercase;\n    letter-spacing: 0.08em;\n    margin: 0 0 16px;\n    color: #ffffff;\n  }\n\n  .amb-subheading {\n    font-size: 16px;\n    font-family: var(--font-body-family);\n    font-style: var(--font-body-style);\n    font-weight: var(--font-body-weight);\n    color: rgba(255,255,255,0.45);\n    margin: 0 auto;\n    max-width: 600px;\n    line-height: 1.6;\n    letter-spacing: 0.02em;\n  }\n\n  .amb-highlight {\n    color: #ffffff;\n    font-family: var(--font-heading-family);\n    font-style: var(--font-heading-style);\n    font-weight: var(--font-heading-weight);\n  }\n\n  /* ===================== GRID ===================== */\n  .amb-grid {\n    display: flex;\n    flex-wrap: wrap;\n    justify-content: center;\n    gap: 4px;\n  }\n\n  /* ===================== CARD ===================== */\n  @keyframes amb-in {\n    from { opacity: 0; transform: translateY(20px); }\n    to   { opacity: 1; transform: translateY(0); }\n  }\n\n  .amb-card {\n    position: relative;\n    width: 130px;\n    flex-shrink: 0;\n    border-radius: 4px;\n    overflow: hidden;\n    display: block;\n    text-decoration: none;\n    opacity: 0;\n    animation: amb-in 0.5s ease forwards;\n  }\n\n  .amb-card:nth-child(1)  { animation-delay: 0.05s; }\n  .amb-card:nth-child(2)  { animation-delay: 0.10s; }\n  .amb-card:nth-child(3)  { animation-delay: 0.15s; }\n  .amb-card:nth-child(4)  { animation-delay: 0.20s; }\n  .amb-card:nth-child(5)  { animation-delay: 0.25s; }\n  .amb-card:nth-child(6)  { animation-delay: 0.30s; }\n  .amb-card:nth-child(7)  { animation-delay: 0.35s; }\n  .amb-card:nth-child(8)  { animation-delay: 0.40s; }\n  .amb-card:nth-child(9)  { animation-delay: 0.45s; }\n  .amb-card:nth-child(10) { animation-delay: 0.50s; }\n  .amb-card:nth-child(11) { animation-delay: 0.55s; }\n\n  /* ===================== PHOTO ===================== */\n  .amb-photo {\n    width: 100%;\n    aspect-ratio: 5 / 6;\n    object-fit: cover;\n    object-position: top center;\n    display: block;\n    filter: grayscale(20%);\n    transition: filter 0.35s ease, transform 0.45s ease;\n  }\n\n  .amb-card:hover .amb-photo {\n    filter: grayscale(0%);\n    transform: scale(1.06);\n  }\n\n  /* ===================== OVERLAY ===================== */\n  .amb-overlay {\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, transparent 55%);\n    display: flex;\n    flex-direction: column;\n    justify-content: flex-end;\n    padding: 10px 8px;\n    opacity: 0.75;\n    transition: opacity 0.3s ease;\n  }\n\n  .amb-card:hover .amb-overlay {\n    opacity: 1;\n  }\n\n  /* ===================== NOME ===================== */\n  .amb-name {\n    margin: 0 0 3px;\n    font-size: 11px;\n    font-family: var(--font-heading-family);\n    font-style: var(--font-heading-style);\n    font-weight: var(--font-heading-weight);\n    text-transform: uppercase;\n    letter-spacing: 0.07em;\n    color: #ffffff;\n    line-height: 1.3;\n  }\n\n  /* ===================== BADGE ===================== */\n  .amb-badge {\n    font-size: 11px;\n    font-family: var(--font-body-family);\n    font-style: var(--font-body-style);\n    font-weight: var(--font-body-weight);\n    letter-spacing: 0.04em;\n    color: #FB6E06;\n  }\n\n  /* ===================== RESPONSIVE ===================== */\n  @media (max-width: 1024px) {\n    .amb-card { width: 110px; }\n  }\n\n  @media (max-width: 768px) {\n    .amb-inner { padding: 0 20px; }\n    .amb-card { width: 90px; }\n    .amb-name { font-size: 10px; }\n    .amb-badge { font-size: 10px; }\n  }\n\n  @media (max-width: 480px) {\n    .amb-section { padding: 40px 0 48px; }\n    .amb-inner { padding: 0 12px; }\n    .amb-header { margin-bottom: 40px; }\n    .amb-grid { gap: 3px; }\n    .amb-card { width: calc(33.333% - 2px); }\n    .amb-subheading { font-size: 14px; }\n    .amb-name { font-size: 9px; }\n    .amb-badge { font-size: 9px; }\n  }\n\n  @media (max-width: 340px) {\n    .amb-card { width: calc(50% - 2px); }\n  }\n</style>",
